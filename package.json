{
  "name": "projectguard-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:engine\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
